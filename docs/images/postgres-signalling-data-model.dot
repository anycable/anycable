digraph postgres_signalling_data_model {
  graph [
    rankdir=LR,
    bgcolor="white",
    pad="0.35",
    nodesep="0.55",
    ranksep="0.8",
    fontname="Inter"
  ];

  node [
    shape=plain,
    fontname="Inter"
  ];

  edge [
    color="#526070",
    fontname="Inter",
    fontsize=12,
    arrowsize=0.8
  ];

  schema_ensure [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="8" COLOR="#526070">
        <TR><TD BGCOLOR="#E7F0F8"><B>Startup schema ensure</B></TD></TR>
        <TR><TD ALIGN="LEFT">idempotent DDL</TD></TR>
        <TR><TD ALIGN="LEFT">catalog validation</TD></TR>
        <TR><TD ALIGN="LEFT">no marker table</TD></TR>
        <TR><TD ALIGN="LEFT"><I>server-owned schema</I></TD></TR>
      </TABLE>
    >
  ];

  app_queue [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="8" COLOR="#526070">
        <TR><TD BGCOLOR="#E9F7EF"><B>anycable_broadcasts</B></TD></TR>
        <TR><TD ALIGN="LEFT">id bigserial primary key</TD></TR>
        <TR><TD ALIGN="LEFT">stream text not null</TD></TR>
        <TR><TD ALIGN="LEFT">payload text not null</TD></TR>
        <TR><TD ALIGN="LEFT">claimed_by text null</TD></TR>
        <TR><TD ALIGN="LEFT">claimed_at timestamptz null</TD></TR>
        <TR><TD ALIGN="LEFT">attempts integer not null default 0</TD></TR>
        <TR><TD ALIGN="LEFT">last_error text null</TD></TR>
        <TR><TD ALIGN="LEFT">created_at timestamptz not null</TD></TR>
        <TR><TD ALIGN="LEFT"><I>single consumer queue</I></TD></TR>
      </TABLE>
    >
  ];

  fanout_queue [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="8" COLOR="#526070">
        <TR><TD BGCOLOR="#FFF4D6"><B>anycable_pubsub</B></TD></TR>
        <TR><TD ALIGN="LEFT">id bigserial primary key</TD></TR>
        <TR><TD ALIGN="LEFT">stream text not null</TD></TR>
        <TR><TD ALIGN="LEFT">payload text not null</TD></TR>
        <TR><TD ALIGN="LEFT">created_at timestamptz not null</TD></TR>
        <TR><TD ALIGN="LEFT"><I>fanout catch-up log</I></TD></TR>
      </TABLE>
    >
  ];

  publish_fn [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="8" COLOR="#526070">
        <TR><TD BGCOLOR="#F2ECFA"><B>SQL functions</B></TD></TR>
        <TR><TD ALIGN="LEFT">anycable_publish(stream, payload, meta)</TD></TR>
        <TR><TD ALIGN="LEFT">anycable_remote_command(payload, meta)</TD></TR>
        <TR><TD ALIGN="LEFT"><I>public app integration surface</I></TD></TR>
      </TABLE>
    >
  ];

  app_queue -> fanout_queue [
    label="claimed row becomes broker broadcast",
    style=dashed
  ];

  publish_fn -> app_queue [
    label="insert app-to-server publication"
  ];

  schema_ensure -> app_queue [
    label="creates and validates",
    style=dotted
  ];

  schema_ensure -> fanout_queue [
    label="creates and validates",
    style=dotted
  ];

  schema_ensure -> publish_fn [
    label="creates functions",
    style=dotted
  ];
}
