digraph postgres_signalling_dataflow {
  graph [
    rankdir=TB,
    bgcolor="white",
    pad="0.35",
    nodesep="0.45",
    ranksep="0.55",
    fontname="Inter"
  ];

  node [
    shape=box,
    style="rounded,filled",
    color="#526070",
    fillcolor="#F7F9FB",
    fontname="Inter",
    fontsize=13,
    margin="0.18,0.11"
  ];

  edge [
    color="#526070",
    fontname="Inter",
    fontsize=12,
    arrowsize=0.8
  ];

  app_link [label="App -> server link\nsingle consumer queue", shape=box, fillcolor="#E9F7EF", fontsize=16];
  app [label="Publishing app\ncalls SQL function", fillcolor="#F2ECFA"];
  broadcasts [label="anycable_broadcasts\nstream + payload + claim state", fillcolor="#E9F7EF"];
  app_notify [label="NOTIFY wake-up\nstable channel, not delivery", fillcolor="#E7F0F8"];
  claim [label="AnyCable nodes poll queue\nFOR UPDATE SKIP LOCKED", fillcolor="#F7F9FB"];
  order_guard [label="per-stream guard\nno older unfinished row", fillcolor="#FFF4D6"];
  winner [label="one node handles row\nack or retry/final failure", fillcolor="#F7F9FB"];

  fanout_link [label="Node -> node link\nfanout catch-up log", shape=box, fillcolor="#FFF4D6", fontsize=16];
  broker [label="Broker emits stream message", fillcolor="#F7F9FB"];
  pubsub [label="anycable_pubsub\nstream + payload log", fillcolor="#FFF4D6"];
  fanout_notify [label="NOTIFY wake-up\npayload includes stream", fillcolor="#E7F0F8"];
  interested [label="nodes keep local\nstream cursors", fillcolor="#F7F9FB"];
  catchup [label="batched catch-up query\nchanged streams first,\nall streams on fallback tick", fillcolor="#F7F9FB"];
  clients [label="subscribed clients\nreceive in stream order", fillcolor="#E9F7EF"];

  { rank=same; app; broadcasts; }
  { rank=same; app_notify; claim; }
  { rank=same; order_guard; winner; }
  { rank=same; broker; pubsub; }
  { rank=same; fanout_notify; interested; }
  { rank=same; catchup; clients; }

  app_link -> app [style=invis];
  app -> broadcasts [label="insert"];
  broadcasts -> app_notify [label="trigger"];
  app_notify -> claim [label="wake"];
  claim -> order_guard [label="candidate rows"];
  order_guard -> winner [label="claim eligible row"];
  winner -> fanout_link [label="HandleBroadcast"];

  fanout_link -> broker [style=invis];
  broker -> pubsub [label="insert fanout row"];
  pubsub -> fanout_notify [label="trigger"];
  fanout_notify -> interested [label="stream changed"];
  interested -> catchup [label="subscribed streams only"];
  catchup -> clients [label="deliver ordered rows"];

  broadcasts -> claim [
    label="polling fallback",
    style=dashed
  ];

  pubsub -> catchup [
    label="polling fallback",
    style=dashed
  ];
}
